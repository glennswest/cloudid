{
  "ignition": { "version": "3.4.0" },
  "storage": {
    "disks": [
      {
        "device": "/dev/sda",
        "wipeTable": true,
        "partitions": [
          {
            "label": "data",
            "number": 1
          }
        ]
      }
    ],
    "filesystems": [
      {
        "device": "/dev/disk/by-partlabel/data",
        "format": "xfs",
        "path": "/var/data",
        "label": "data",
        "wipeFilesystem": true
      }
    ],
    "links": [
      {
        "path": "/etc/localtime",
        "target": "/usr/share/zoneinfo/America/Chicago",
        "overwrite": true
      }
    ],
    "files": [
      {
        "path": "/etc/hostname",
        "mode": 420,
        "overwrite": true,
        "contents": {
          "source": "data:,{{HOSTNAME_ENCODED}}"
        }
      },
      {
        "path": "/etc/containers/registries.conf.d/registry-gt-lo.conf",
        "mode": 420,
        "contents": {
          "source": "data:,%5B%5Bregistry%5D%5D%0Alocation%20%3D%20%22registry.gt.lo%3A5000%22%0Ainsecure%20%3D%20true%0A"
        }
      },
      {
        "path": "/etc/modules-load.d/fuse.conf",
        "mode": 420,
        "contents": {
          "source": "data:,fuse%0A"
        }
      },
      {
        "path": "/etc/modules-load.d/ublk.conf",
        "mode": 420,
        "contents": {
          "source": "data:,ublk_drv%0A"
        }
      },
      {
        "path": "/etc/modules-load.d/iscsi.conf",
        "mode": 420,
        "contents": {
          "source": "data:,iscsi_tcp%0Aiscsi_target_mod%0Atarget_core_mod%0A"
        }
      },
      {
        "path": "/etc/modules-load.d/bonding.conf",
        "mode": 420,
        "contents": {
          "source": "data:,bonding%0A"
        }
      },
      {
        "path": "/etc/NetworkManager/system-connections/bond0.nmconnection",
        "mode": 384,
        "overwrite": true,
        "contents": {
          "source": "data:;base64,W2Nvbm5lY3Rpb25dCmlkPWJvbmQwCnR5cGU9Ym9uZAppbnRlcmZhY2UtbmFtZT1ib25kMAoKW2JvbmRdCm1vZGU9ODAyLjNhZAptaWltb249MTAwCmxhY3BfcmF0ZT1mYXN0CnhtaXRfaGFzaF9wb2xpY3k9bGF5ZXIzKzQKCltpcHY0XQptZXRob2Q9YXV0bwoKW2lwdjZdCm1ldGhvZD1hdXRvCg=="
        }
      },
      {
        "path": "/etc/NetworkManager/system-connections/bond0-port-enp3s0.nmconnection",
        "mode": 384,
        "overwrite": true,
        "contents": {
          "source": "data:;base64,W2Nvbm5lY3Rpb25dCmlkPWJvbmQwLXBvcnQtZW5wM3MwCnR5cGU9ZXRoZXJuZXQKaW50ZXJmYWNlLW5hbWU9ZW5wM3MwCm1hc3Rlcj1ib25kMApzbGF2ZS10eXBlPWJvbmQK"
        }
      },
      {
        "path": "/etc/NetworkManager/system-connections/bond0-port-enp5s0.nmconnection",
        "mode": 384,
        "overwrite": true,
        "contents": {
          "source": "data:;base64,W2Nvbm5lY3Rpb25dCmlkPWJvbmQwLXBvcnQtZW5wNXMwCnR5cGU9ZXRoZXJuZXQKaW50ZXJmYWNlLW5hbWU9ZW5wNXMwCm1hc3Rlcj1ib25kMApzbGF2ZS10eXBlPWJvbmQK"
        }
      }
    ]
  },
  "systemd": {
    "units": [
      {
        "name": "NetworkManager-wait-online.service",
        "mask": true
      },
      {
        "name": "var-data.mount",
        "enabled": true,
        "contents": "[Unit]\nDescription=Mount data disk\n\n[Mount]\nWhat=/dev/disk/by-partlabel/data\nWhere=/var/data\nType=xfs\n\n[Install]\nWantedBy=local-fs.target\n"
      },
      {
        "name": "podman.socket",
        "enabled": true
      },
      {
        "name": "mkube-agent.service",
        "enabled": true,
        "contents": "[Unit]\nDescription=mkube job agent (container)\nAfter=network-online.target var-data.mount podman.socket\nWants=network-online.target\nRequires=var-data.mount podman.socket\n\n[Service]\nType=simple\nRestart=always\nRestartSec=5\nExecStartPre=/bin/bash -c 'echo Waiting for DNS...; for i in $(seq 1 60); do getent hosts registry.gt.lo && exit 0; sleep 2; done; echo DNS timeout; exit 1'\nExecStartPre=-/usr/bin/podman rm -f mkube-agent\nExecStartPre=/usr/bin/mkdir -p /var/data/agent-storage /var/data/tmp\nExecStart=/usr/bin/podman run --name mkube-agent --rm --network host --privileged -v /var/data:/data -v /var/data/agent-storage:/var/lib/containers -v /var/data/tmp:/var/tmp -v /run/podman/podman.sock:/run/podman/podman.sock -e TMPDIR=/data/tmp -e MKUBE_API=http://192.168.200.2:8082 -e CONTAINER_HOST=unix:///run/podman/podman.sock --pull=always --arch amd64 registry.gt.lo:5000/mkube-agent:edge\nExecStop=/usr/bin/podman stop mkube-agent\nTimeoutStartSec=900\nStandardOutput=journal\nStandardError=journal\n\n[Install]\nWantedBy=multi-user.target\n"
      }
    ]
  }
}
